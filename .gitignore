# Environment
.env

# Generated assets — downloads are cleaned up by pipeline
assets/downloads/*
assets/clips/*
assets/thumbnails/*
assets/thumbnails/variants/*

# Keep log files (track history)
!assets/logs/*

# But ignore runtime artifacts (regenerated every run)
assets/logs/_frames/
assets/logs/pipeline_state.json

# YouTube OAuth token
youtube_token.pickle
upload_token.pickle

# Python cache
__pycache__/
*.pyc
*.pyo

# Temp files
*.tmp
*.log
*TEMP_MPY*
cookies_*.txt

# OS files
Thumbs.db
.DS_Store
nul

# Misc junk
New Text Document.txt
