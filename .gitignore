# Environment
.env

# Generated assets — downloads are cleaned up by pipeline
assets/downloads/*
assets/clips/*
assets/thumbnails/*
assets/thumbnails/variants/*

# Keep log files (track history)
!assets/logs/*

# YouTube OAuth token
youtube_token.pickle

# Python cache
__pycache__/
*.pyc
*.pyo

# Temp files
*.tmp
*.log
*TEMP_MPY*

# OS files
Thumbs.db
.DS_Store
